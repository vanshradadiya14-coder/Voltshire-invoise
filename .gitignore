# ---- Firebase per-app config ----
# Committed on purpose: the CI build has no local Firebase login, so these
# real per-app config files (client keys, safe-ish) must ship in the repo.
# Overwrite them by running `flutterfire configure` if you rotate the project.
# google-services.json
# GoogleService-Info.plist
# Note: lib/firebase/firebase_options.dart IS committed so the project compiles.

# Exceptions to version control
!**/ios/**/default.mode1v3
!**/ios/**/default.mode2v3
!**/ios/**/default.pbxuser
!**/ios/**/default.perspectivev3
